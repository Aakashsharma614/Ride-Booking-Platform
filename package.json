{
  "name": "ride-booking-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "libs/*",
    "services/*"
  ],
  "scripts": {
    "dev:gateway": "npm run dev -w @ride/api-gateway",
    "dev:web": "npm run dev -w @ride/web",
    "test": "node --test \"libs/**/*.test.js\" \"services/**/*.test.js\"",
    "lint": "eslint .",
    "build": "npm run build -w @ride/web",
    "docker:up": "docker compose -f infrastructure/docker-compose.yml up --build",
    "k8s:apply": "kubectl apply -f infrastructure/kubernetes"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.56.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.200.0",
    "@opentelemetry/sdk-node": "^0.200.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.18.0",
    "morgan": "^1.10.1",
    "prom-client": "^15.1.3",
    "uuid": "^11.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.29.0",
    "vite": "^6.3.5"
  }
}
